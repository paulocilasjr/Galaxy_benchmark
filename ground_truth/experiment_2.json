{
  "format_version": "galaxy_benchmark_ground_truth_v2",
  "task_id": "experiment_2",
  "result_format": "galaxy_benchmark_result_v2",
  "benchmark_axes": {
    "scientist_level_band": "junior",
    "galaxy_complexity_band": "intermediate"
  },
  "scientific_answer": {
    "target": {
      "comparison_mode": "exact",
      "canonical_value": "dx"
    },
    "primary_metric": {
      "name": "ROC-AUC",
      "split": "test",
      "comparison_mode": "at_least",
      "threshold": 0.93
    }
  },
  "galaxy_execution": {
    "final_entity_type": "tool",
    "final_entity_name": {
      "comparison_mode": "reported_choice_consistent_with_run_artifacts",
      "acceptable_entity_classes": [
        "biomedical image classification tool"
      ]
    },
    "history_input_mode": "remote_fetch",
    "required_capabilities": [
      "remote data upload",
      "history dataset inspection",
      "tool invocation",
      "run-state monitoring"
    ],
    "acceptable_adaptation_summaries": [
      "single_valid_run",
      "justified_retry"
    ]
  },
  "tier_specific_expectations": {
    "high_context": {
      "galaxy_execution": {
        "final_entity_name": {
          "comparison_mode": "alias_match",
          "canonical_value": "Image Learner",
          "accepted_aliases": [
            "image learner"
          ]
        }
      }
    }
  },
  "fair_scoring": {
    "normalize_case": true,
    "normalize_metric_name_aliases": [
      "ROC-AUC",
      "roc_auc",
      "roc-auc"
    ],
    "score_scientific_answer_and_galaxy_execution_separately": true,
    "preserve_three_score_vector": true,
    "score_model_support": {
      "scientific_solution_score": {
        "primary_section": "scientific_answer",
        "rule": "Use the base scientific criteria to judge whether the solution is scientifically useful."
      },
      "standard_analysis_score": {
        "primary_section": "tier_specific_expectations",
        "rule": "Use only explicit standard-path constraints; if no meaningful standard path is defined for a tier, this score may be treated as not_applicable."
      },
      "galaxy_execution_score": {
        "primary_section": "galaxy_execution",
        "rule": "Use only Galaxy-environment manipulation, access, monitoring, recovery, and provenance expectations."
      }
    },
    "score_aggregation": "weighted_average",
    "score_status_thresholds": {
      "pass": 0.85,
      "partial": 0.5
    },
    "auditability_belongs_to_galaxy_execution_score": true,
    "only_trace_backed_reporting_gets_full_credit": true
  }
}
