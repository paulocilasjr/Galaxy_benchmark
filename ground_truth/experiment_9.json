{
  "format_version": "galaxy_benchmark_ground_truth_v2",
  "task_id": "experiment_9",
  "result_format": "galaxy_benchmark_result_v2",
  "benchmark_axes": {
    "scientist_level_band": "intermediate",
    "galaxy_complexity_band": "advanced"
  },
  "scientific_answer": {
    "chowell_test_accuracy": {
      "comparison_mode": "at_least",
      "threshold": 0.8
    },
    "msk1_test_accuracy": {
      "comparison_mode": "at_least",
      "threshold": 0.72
    }
  },
  "galaxy_execution": {
    "final_entity_type": "workflow",
    "final_entity_name": {
      "comparison_mode": "reported_choice_consistent_with_run_artifacts",
      "acceptable_entity_classes": [
        "workflow-built tabular ml pipeline"
      ]
    },
    "history_input_mode": {
      "comparison_mode": "alias_match",
      "canonical_value": "mixed",
      "accepted_aliases": [
        "local_upload_and_remote_fetch"
      ]
    },
    "workflow_exported": true,
    "acceptable_adaptation_summaries": [
      "single_valid_run",
      "justified_retry"
    ]
  },
  "tier_specific_expectations": {
    "high_context": {
      "scientific_answer": {
        "tuning_strategy": {
          "comparison_mode": "alias_match",
          "canonical_value": "SearchCV",
          "accepted_aliases": [
            "searchcv"
          ]
        }
      },
      "galaxy_execution": {
        "final_entity_name": {
          "comparison_mode": "alias_match",
          "canonical_value": "Pipeline Builder",
          "accepted_aliases": [
            "pipeline builder"
          ]
        }
      }
    }
  },
  "fair_scoring": {
    "normalize_case": true,
    "score_scientific_answer_and_galaxy_execution_separately": true,
    "preserve_three_score_vector": true,
    "score_model_support": {
      "scientific_solution_score": {
        "primary_section": "scientific_answer",
        "rule": "Use internal and external validation quality."
      },
      "standard_analysis_score": {
        "primary_section": "tier_specific_expectations",
        "rule": "Use only explicit workflow-builder and SearchCV constraints."
      },
      "galaxy_execution_score": {
        "primary_section": "galaxy_execution",
        "rule": "Use workflow execution, mixed-input handling, and provenance."
      }
    },
    "score_aggregation": "weighted_average",
    "score_status_thresholds": {
      "pass": 0.85,
      "partial": 0.5
    },
    "auditability_belongs_to_galaxy_execution_score": true,
    "only_trace_backed_reporting_gets_full_credit": true
  }
