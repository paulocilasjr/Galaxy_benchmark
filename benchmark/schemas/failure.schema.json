{
  "$defs": {
    "FailureCategory": {
      "enum": [
        "task_understanding",
        "workflow_discovery",
        "tool_discovery",
        "input_mapping",
        "parameter_grounding",
        "execution_control",
        "polling_or_waiting",
        "output_interpretation",
        "provenance_failure",
        "knowledge_retrieval_failure",
        "knowledge_adaptation_failure",
        "unnecessary_autonomy",
        "unsupported_capability",
        "hallucinated_action",
        "unsafe_defaulting",
        "incomplete_recovery",
        "unknown"
      ],
      "title": "FailureCategory",
      "type": "string"
    },
    "FailureEvidence": {
      "additionalProperties": false,
      "description": "Evidence linked to a failure.",
      "properties": {
        "message": {
          "title": "Message",
          "type": "string"
        },
        "step": {
          "title": "Step",
          "type": "string"
        },
        "job_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Job Id"
        },
        "invocation_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Invocation Id"
        },
        "exit_code": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Exit Code"
        },
        "artifact_paths": {
          "items": {
            "type": "string"
          },
          "title": "Artifact Paths",
          "type": "array"
        }
      },
      "required": [
        "message",
        "step"
      ],
      "title": "FailureEvidence",
      "type": "object"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "A classified failure event.",
  "properties": {
    "failure_id": {
      "title": "Failure Id",
      "type": "string"
    },
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "category": {
      "$ref": "#/$defs/FailureCategory"
    },
    "subcategory": {
      "title": "Subcategory",
      "type": "string"
    },
    "severity": {
      "$ref": "#/$defs/Severity"
    },
    "signature": {
      "title": "Signature",
      "type": "string"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/FailureEvidence"
      },
      "title": "Evidence",
      "type": "array"
    },
    "root_cause": {
      "title": "Root Cause",
      "type": "string"
    },
    "recoverable": {
      "title": "Recoverable",
      "type": "boolean"
    },
    "recovered": {
      "default": false,
      "title": "Recovered",
      "type": "boolean"
    },
    "notes": {
      "items": {
        "type": "string"
      },
      "title": "Notes",
      "type": "array"
    }
  },
  "required": [
    "failure_id",
    "task_id",
    "run_id",
    "category",
    "subcategory",
    "severity",
    "signature",
    "root_cause",
    "recoverable"
  ],
  "title": "FailureRecord",
  "type": "object"
}
