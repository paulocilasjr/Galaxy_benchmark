{
  "$defs": {
    "ArtifactType": {
      "enum": [
        "task_snapshot",
        "prompt_variant",
        "run_configuration",
        "environment_snapshot",
        "result",
        "score",
        "failure_analysis",
        "comparison",
        "reproduction",
        "trace",
        "report"
      ],
      "title": "ArtifactType",
      "type": "string"
    },
    "FailureCategory": {
      "enum": [
        "task_understanding",
        "workflow_discovery",
        "tool_discovery",
        "input_mapping",
        "parameter_grounding",
        "execution_control",
        "polling_or_waiting",
        "output_interpretation",
        "provenance_failure",
        "knowledge_retrieval_failure",
        "knowledge_adaptation_failure",
        "unnecessary_autonomy",
        "unsupported_capability",
        "hallucinated_action",
        "unsafe_defaulting",
        "incomplete_recovery",
        "unknown"
      ],
      "title": "FailureCategory",
      "type": "string"
    },
    "FailureEvidence": {
      "additionalProperties": false,
      "description": "Evidence linked to a failure.",
      "properties": {
        "message": {
          "title": "Message",
          "type": "string"
        },
        "step": {
          "title": "Step",
          "type": "string"
        },
        "job_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Job Id"
        },
        "invocation_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Invocation Id"
        },
        "exit_code": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Exit Code"
        },
        "artifact_paths": {
          "items": {
            "type": "string"
          },
          "title": "Artifact Paths",
          "type": "array"
        }
      },
      "required": [
        "message",
        "step"
      ],
      "title": "FailureEvidence",
      "type": "object"
    },
    "FailureRecord": {
      "additionalProperties": false,
      "description": "A classified failure event.",
      "properties": {
        "failure_id": {
          "title": "Failure Id",
          "type": "string"
        },
        "task_id": {
          "title": "Task Id",
          "type": "string"
        },
        "run_id": {
          "title": "Run Id",
          "type": "string"
        },
        "category": {
          "$ref": "#/$defs/FailureCategory"
        },
        "subcategory": {
          "title": "Subcategory",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "signature": {
          "title": "Signature",
          "type": "string"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/FailureEvidence"
          },
          "title": "Evidence",
          "type": "array"
        },
        "root_cause": {
          "title": "Root Cause",
          "type": "string"
        },
        "recoverable": {
          "title": "Recoverable",
          "type": "boolean"
        },
        "recovered": {
          "default": false,
          "title": "Recovered",
          "type": "boolean"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "failure_id",
        "task_id",
        "run_id",
        "category",
        "subcategory",
        "severity",
        "signature",
        "root_cause",
        "recoverable"
      ],
      "title": "FailureRecord",
      "type": "object"
    },
    "RunStatus": {
      "enum": [
        "pending",
        "running",
        "completed",
        "completed_with_errors",
        "failed"
      ],
      "title": "RunStatus",
      "type": "string"
    },
    "ScoreCard": {
      "additionalProperties": false,
      "description": "Outcome, process, and robustness scoring.",
      "properties": {
        "outcome_score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Outcome Score",
          "type": "number"
        },
        "process_score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Process Score",
          "type": "number"
        },
        "robustness_score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Robustness Score",
          "type": "number"
        },
        "total_score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Total Score",
          "type": "number"
        },
        "component_weights": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Component Weights",
          "type": "object"
        },
        "subscores": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Subscores",
          "type": "object"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "outcome_score",
        "process_score",
        "robustness_score",
        "total_score"
      ],
      "title": "ScoreCard",
      "type": "object"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Bundle of result fields, score, and failures for a run.",
  "properties": {
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/RunStatus"
    },
    "extracted_outputs": {
      "additionalProperties": true,
      "title": "Extracted Outputs",
      "type": "object"
    },
    "scorecard": {
      "anyOf": [
        {
          "$ref": "#/$defs/ScoreCard"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "failures": {
      "items": {
        "$ref": "#/$defs/FailureRecord"
      },
      "title": "Failures",
      "type": "array"
    },
    "artifacts": {
      "additionalProperties": {
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "propertyNames": {
        "$ref": "#/$defs/ArtifactType"
      },
      "title": "Artifacts",
      "type": "object"
    }
  },
  "required": [
    "task_id",
    "run_id",
    "status"
  ],
  "title": "EvaluationResult",
  "type": "object"
}
