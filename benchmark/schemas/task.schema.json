{
  "$defs": {
    "BenchmarkPillar": {
      "enum": [
        "platform_operation_capability",
        "prompt_robustness_and_trust",
        "ecosystem_knowledge_use"
      ],
      "title": "BenchmarkPillar",
      "type": "string"
    },
    "ExpectedOutputField": {
      "additionalProperties": false,
      "description": "A normalized output field expected from a run.",
      "properties": {
        "field": {
          "title": "Field",
          "type": "string"
        },
        "value_type": {
          "title": "Value Type",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "source_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Key"
        },
        "legacy_field": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Legacy Field"
        },
        "source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source"
        }
      },
      "required": [
        "field",
        "value_type",
        "description"
      ],
      "title": "ExpectedOutputField",
      "type": "object"
    },
    "InputAsset": {
      "additionalProperties": false,
      "description": "A typed reference to an input used by a benchmark task.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "source_type": {
          "$ref": "#/$defs/SourceType"
        },
        "path_or_url": {
          "title": "Path Or Url",
          "type": "string"
        },
        "format": {
          "title": "Format",
          "type": "string"
        },
        "role": {
          "title": "Role",
          "type": "string"
        },
        "checksum": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Checksum"
        },
        "optional": {
          "default": false,
          "title": "Optional",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "source_type",
        "path_or_url",
        "format",
        "role"
      ],
      "title": "InputAsset",
      "type": "object"
    },
    "KnowledgeCondition": {
      "enum": [
        "none",
        "gtn_only",
        "iwc_only",
        "gtn_and_iwc",
        "raw_web",
        "mcp_exposed"
      ],
      "title": "KnowledgeCondition",
      "type": "string"
    },
    "KnowledgeRequirement": {
      "additionalProperties": false,
      "description": "Knowledge sources or conditions required by a task.",
      "properties": {
        "conditions": {
          "items": {
            "$ref": "#/$defs/KnowledgeCondition"
          },
          "title": "Conditions",
          "type": "array"
        },
        "sources": {
          "items": {
            "type": "string"
          },
          "title": "Sources",
          "type": "array"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "title": "KnowledgeRequirement",
      "type": "object"
    },
    "ProcessConstraints": {
      "additionalProperties": false,
      "description": "Process-level rules that executions must obey.",
      "properties": {
        "must_log_trace": {
          "default": true,
          "title": "Must Log Trace",
          "type": "boolean"
        },
        "must_not_read_ground_truth_before_result": {
          "default": true,
          "title": "Must Not Read Ground Truth Before Result",
          "type": "boolean"
        },
        "write_boundary_roots": {
          "items": {
            "type": "string"
          },
          "title": "Write Boundary Roots",
          "type": "array"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "title": "ProcessConstraints",
      "type": "object"
    },
    "SourceType": {
      "enum": [
        "local",
        "url",
        "galaxy_dataset",
        "generated"
      ],
      "title": "SourceType",
      "type": "string"
    },
    "SuccessCriteria": {
      "additionalProperties": false,
      "description": "Success conditions for the task outcome.",
      "properties": {
        "required_fields": {
          "items": {
            "type": "string"
          },
          "title": "Required Fields",
          "type": "array"
        },
        "metric_thresholds": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Metric Thresholds",
          "type": "object"
        },
        "artifact_requirements": {
          "items": {
            "type": "string"
          },
          "title": "Artifact Requirements",
          "type": "array"
        }
      },
      "title": "SuccessCriteria",
      "type": "object"
    },
    "TaskDefinition": {
      "additionalProperties": false,
      "description": "Structured execution expectations for a benchmark task.",
      "properties": {
        "goal": {
          "title": "Goal",
          "type": "string"
        },
        "required_actions": {
          "items": {
            "type": "string"
          },
          "title": "Required Actions",
          "type": "array"
        },
        "tool_hints": {
          "items": {
            "type": "string"
          },
          "title": "Tool Hints",
          "type": "array"
        },
        "target_outputs": {
          "items": {
            "$ref": "#/$defs/ExpectedOutputField"
          },
          "title": "Target Outputs",
          "type": "array"
        }
      },
      "required": [
        "goal"
      ],
      "title": "TaskDefinition",
      "type": "object"
    },
    "TaskFamily": {
      "enum": [
        "basic_galaxy_operations",
        "single_tool_execution",
        "workflow_retrieval_and_execution",
        "tutorial_grounded_execution",
        "optimization_and_parameter_search",
        "failure_recovery",
        "provenance_and_reproducibility"
      ],
      "title": "TaskFamily",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Canonical benchmark task definition.",
  "properties": {
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "suite_id": {
      "title": "Suite Id",
      "type": "string"
    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "description": {
      "title": "Description",
      "type": "string"
    },
    "task_family": {
      "$ref": "#/$defs/TaskFamily"
    },
    "task_subfamily": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Task Subfamily"
    },
    "benchmark_pillars": {
      "items": {
        "$ref": "#/$defs/BenchmarkPillar"
      },
      "title": "Benchmark Pillars",
      "type": "array"
    },
    "difficulty_level": {
      "minimum": 1,
      "title": "Difficulty Level",
      "type": "integer"
    },
    "galaxy_instance": {
      "title": "Galaxy Instance",
      "type": "string"
    },
    "input_assets": {
      "items": {
        "$ref": "#/$defs/InputAsset"
      },
      "title": "Input Assets",
      "type": "array"
    },
    "expected_outputs": {
      "items": {
        "$ref": "#/$defs/ExpectedOutputField"
      },
      "title": "Expected Outputs",
      "type": "array"
    },
    "knowledge_requirements": {
      "$ref": "#/$defs/KnowledgeRequirement"
    },
    "tool_hints": {
      "items": {
        "type": "string"
      },
      "title": "Tool Hints",
      "type": "array"
    },
    "workflow_hints": {
      "items": {
        "type": "string"
      },
      "title": "Workflow Hints",
      "type": "array"
    },
    "success_criteria": {
      "$ref": "#/$defs/SuccessCriteria"
    },
    "process_constraints": {
      "$ref": "#/$defs/ProcessConstraints"
    },
    "failure_scenarios": {
      "items": {
        "type": "string"
      },
      "title": "Failure Scenarios",
      "type": "array"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "task_definition": {
      "anyOf": [
        {
          "$ref": "#/$defs/TaskDefinition"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "task_id",
    "suite_id",
    "title",
    "description",
    "task_family",
    "difficulty_level",
    "galaxy_instance"
  ],
  "title": "BenchmarkTask",
  "type": "object"
}
