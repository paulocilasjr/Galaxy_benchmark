{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GalaxyBenchmarkRun",
  "type": "object",
  "required": [
    "run_id",
    "task_id",
    "prompt_level",
    "environment",
    "agent_id",
    "input_prompt",
    "status",
    "component_scores",
    "performance_score"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "prompt_level": {
      "type": "string",
      "enum": [
        "vague",
        "specific",
        "very_specific"
      ]
    },
    "environment": {
      "type": "string",
      "enum": [
        "open",
        "galaxy",
        "galaxy_skills"
      ]
    },
    "agent_id": {
      "type": "string"
    },
    "input_prompt": {
      "type": "string"
    },
    "outputs": {
      "type": [
        "object",
        "null"
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "trace": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "partial",
        "failed",
        "timeout"
      ]
    },
    "timing": {
      "type": [
        "object",
        "null"
      ]
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "component_scores": {
      "type": "object",
      "required": [
        "correctness",
        "execution",
        "scientific_validity",
        "reproducibility",
        "interpretation"
      ],
      "properties": {
        "correctness": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "execution": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "scientific_validity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reproducibility": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "interpretation": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "performance_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}