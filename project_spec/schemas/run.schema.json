{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GalaxyBenchmarkRunV03",
  "type": "object",
  "required": [
    "run_id",
    "task_id",
    "prompt_level",
    "environment",
    "agent_id",
    "input_prompt",
    "status",
    "component_scores",
    "performance_score",
    "score_vector",
    "operational_metrics"
  ],
  "properties": {
    "run_id": {"type": "string"},
    "task_id": {"type": "string"},
    "prompt_level": {
      "type": "string",
      "enum": [
        "low_context",
        "medium_context",
        "high_context",
        "vague",
        "specific",
        "very_specific"
      ]
    },
    "environment": {
      "type": "string",
      "enum": ["open", "galaxy", "galaxy_skills"]
    },
    "agent_id": {"type": "string"},
    "input_prompt": {"type": "string"},
    "outputs": {
      "type": ["object", "null"]
    },
    "artifacts": {
      "type": "array",
      "items": {"type": "object"}
    },
    "trace": {
      "type": ["array", "null"],
      "items": {"type": "object"}
    },
    "trace_manifest": {
      "type": ["object", "null"]
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed", "timeout"]
    },
    "timing": {
      "type": ["object", "null"]
    },
    "execution_mode": {
      "type": "string"
    },
    "benchmark_validity": {
      "type": ["object", "null"]
    },
    "execution_context": {
      "type": ["object", "null"]
    },
    "failure_modes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "retry_chain": {
      "type": ["array", "null"],
      "items": {"type": "object"}
    },
    "confidence_record": {
      "type": ["object", "null"]
    },
    "score_vector": {
      "type": "object",
      "required": [
        "scientific_solution_score",
        "standard_analysis_score",
        "galaxy_execution_score"
      ],
      "properties": {
        "scientific_solution_score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "standard_analysis_score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "galaxy_execution_score": {"type": ["number", "null"], "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "operational_metrics": {
      "type": "object",
      "required": [
        "pipeline_completion_rate",
        "tool_selection_accuracy",
        "workflow_coherence",
        "parameterization_accuracy",
        "preprocessing_accuracy",
        "result_quality"
      ],
      "properties": {
        "pipeline_completion_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "tool_selection_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "workflow_coherence": {"type": "number", "minimum": 0, "maximum": 1},
        "parameterization_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "preprocessing_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "result_quality": {"type": "number", "minimum": 0, "maximum": 1},
        "confidence_calibration": {"type": ["number", "null"], "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "component_scores": {
      "type": "object",
      "required": [
        "correctness",
        "execution",
        "scientific_validity",
        "reproducibility",
        "interpretation"
      ],
      "properties": {
        "correctness": {"type": "number", "minimum": 0, "maximum": 1},
        "execution": {"type": "number", "minimum": 0, "maximum": 1},
        "scientific_validity": {"type": "number", "minimum": 0, "maximum": 1},
        "reproducibility": {"type": "number", "minimum": 0, "maximum": 1},
        "interpretation": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "performance_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
