{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GalaxyBenchmarkPrompt",
  "type": "object",
  "required": [
    "prompt_id",
    "task_id",
    "specificity_level",
    "text"
  ],
  "properties": {
    "prompt_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "specificity_level": {
      "type": "string",
      "enum": [
        "vague",
        "specific",
        "very_specific"
      ]
    },
    "text": {
      "type": "string"
    }
  },
  "additionalProperties": false
}