{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GalaxyBenchmarkPromptV03",
  "type": "object",
  "required": [
    "prompt_id",
    "task_id",
    "specificity_level",
    "text"
  ],
  "properties": {
    "prompt_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "specificity_level": {
      "type": "string",
      "enum": [
        "low_context",
        "medium_context",
        "high_context",
        "vague",
        "specific",
        "very_specific"
      ]
    },
    "style": {
      "type": "string"
    },
    "user_persona": {
      "type": "string"
    },
    "ambiguity_band": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "text": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
