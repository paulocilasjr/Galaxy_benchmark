{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GalaxyBenchmarkReportV03",
  "type": "object",
  "required": [
    "benchmark_id",
    "agents",
    "task_count",
    "environments",
    "metrics"
  ],
  "properties": {
    "benchmark_id": {"type": "string"},
    "agents": {
      "type": "array",
      "items": {"type": "string"}
    },
    "task_count": {
      "type": "integer",
      "minimum": 1
    },
    "environments": {
      "type": "array",
      "items": {"type": "string"}
    },
    "metrics": {
      "type": "object",
      "required": [
        "overall_performance",
        "overall_robustness",
        "score_vector_summary",
        "endpoint_summary"
      ],
      "properties": {
        "overall_performance": {"type": "object"},
        "overall_robustness": {"type": "object"},
        "score_vector_summary": {"type": "object"},
        "endpoint_summary": {"type": "object"},
        "adaptability": {"type": "object"},
        "user_level_confidence": {"type": "object"}
      },
      "additionalProperties": false
    },
    "per_agent": {
      "type": "array",
      "items": {"type": "object"}
    },
    "per_task": {
      "type": "array",
      "items": {"type": "object"}
    }
  },
  "additionalProperties": false
}
