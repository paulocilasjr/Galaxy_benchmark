{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GalaxyBenchmarkReport",
  "type": "object",
  "required": [
    "benchmark_id",
    "agents",
    "task_count",
    "environments",
    "metrics"
  ],
  "properties": {
    "benchmark_id": {
      "type": "string"
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "task_count": {
      "type": "integer",
      "minimum": 1
    },
    "environments": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "type": "object"
    },
    "per_agent": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "per_task": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false
}