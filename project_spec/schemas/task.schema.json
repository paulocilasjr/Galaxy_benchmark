{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GalaxyBenchmarkTask",
  "type": "object",
  "required": [
    "task_id",
    "title",
    "domain",
    "description",
    "complexity",
    "datasets",
    "ground_truth",
    "acceptable_solutions",
    "requires_iteration",
    "evaluation_spec"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "complexity": {
      "type": "string",
      "enum": [
        "simple",
        "complex",
        "very_complex"
      ]
    },
    "datasets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "path",
          "format"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "format": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "ground_truth": {
      "type": "object"
    },
    "acceptable_solutions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "requires_iteration": {
      "type": "boolean"
    },
    "iteration_budget": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "evaluation_spec": {
      "type": "object"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}