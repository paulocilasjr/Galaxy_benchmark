{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GalaxyBenchmarkTaskV03",
  "type": "object",
  "required": [
    "task_id",
    "title",
    "domain",
    "scientist_help_band",
    "galaxy_complexity_band",
    "description",
    "datasets",
    "task_objective",
    "required_final_artifacts",
    "required_steps",
    "preprocessing_requirements",
    "parameter_targets",
    "acceptable_tool_classes",
    "acceptable_solution_families",
    "human_baseline_protocol",
    "confidence_query_policy",
    "evaluation_spec",
    "ground_truth_contract"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "scientist_help_band": {
      "type": "string",
      "enum": ["junior", "intermediate", "advanced"]
    },
    "galaxy_complexity_band": {
      "type": "string",
      "enum": ["basic", "intermediate", "advanced"]
    },
    "description": {
      "type": "string"
    },
    "datasets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path", "format"],
        "properties": {
          "name": {"type": "string"},
          "path": {"type": "string"},
          "format": {"type": "string"},
          "description": {"type": "string"},
          "role": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "task_objective": {
      "type": "object",
      "required": ["biomedical_goal", "execution_environment"],
      "properties": {
        "biomedical_goal": {"type": "string"},
        "execution_environment": {"type": "string"},
        "primary_output_contract": {"type": "string"}
      },
      "additionalProperties": false
    },
    "required_final_artifacts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "required_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step_id", "description"],
        "properties": {
          "step_id": {"type": "string"},
          "description": {"type": "string"},
          "acceptable_tool_classes": {
            "type": "array",
            "items": {"type": "string"}
          },
          "required": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "preprocessing_requirements": {
      "type": "array",
      "items": {"type": "string"}
    },
    "parameter_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "importance"],
        "properties": {
          "name": {"type": "string"},
          "importance": {"type": "string", "enum": ["critical", "important", "optional"]},
          "reference_expectation": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "acceptable_tool_classes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "acceptable_solution_families": {
      "type": "array",
      "items": {"type": "string"}
    },
    "human_baseline_protocol": {
      "type": "object",
      "required": ["expertise_assumption", "time_budget_minutes"],
      "properties": {
        "expertise_assumption": {"type": "string"},
        "time_budget_minutes": {"type": "integer", "minimum": 1},
        "tooling_access": {"type": "string"}
      },
      "additionalProperties": false
    },
    "confidence_query_policy": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {"type": "string", "enum": ["none", "pre_run", "post_plan", "pre_submit", "post_run"]},
        "scale": {"type": "string"}
      },
      "additionalProperties": false
    },
    "evaluation_spec": {
      "type": "object"
    },
    "ground_truth_contract": {
      "type": "object"
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": false
}
