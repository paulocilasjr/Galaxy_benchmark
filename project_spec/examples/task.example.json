{
  "task_id": "de_rnaseq_001",
  "title": "Differential expression on two-condition RNA-seq dataset",
  "domain": "transcriptomics",
  "scientist_help_band": "intermediate",
  "galaxy_complexity_band": "advanced",
  "description": "Identify genes upregulated in biofilm relative to planktonic growth and return a ranked gene table in Galaxy.",
  "datasets": [
    {
      "name": "reads",
      "path": "dataset/de_rnaseq_001/reads/",
      "format": "fastq.gz",
      "description": "Paired-end RNA-seq reads.",
      "role": "primary_input"
    },
    {
      "name": "reference_genome",
      "path": "dataset/de_rnaseq_001/reference.fa",
      "format": "fasta",
      "description": "Reference genome for alignment.",
      "role": "reference"
    }
  ],
  "task_objective": {
    "biomedical_goal": "Find genes upregulated in biofilm.",
    "execution_environment": "Galaxy",
    "primary_output_contract": "CSV with gene_id, log2_fold_change, p_value, adjusted_p_value."
  },
  "required_final_artifacts": [
    "ranked_gene_table.csv"
  ],
  "required_steps": [
    {
      "step_id": "align_reads",
      "description": "Align reads to the reference genome.",
      "acceptable_tool_classes": ["rna_seq_aligner"],
      "required": true
    },
    {
      "step_id": "count_features",
      "description": "Generate gene-level counts.",
      "acceptable_tool_classes": ["feature_counter"],
      "required": true
    },
    {
      "step_id": "run_differential_expression",
      "description": "Run DE analysis.",
      "acceptable_tool_classes": ["differential_expression"],
      "required": true
    }
  ],
  "preprocessing_requirements": [
    "Input FASTQ files must be paired correctly.",
    "Reference and annotation must be format-compatible with downstream tools."
  ],
  "parameter_targets": [
    {
      "name": "condition_assignment",
      "importance": "critical",
      "reference_expectation": "biofilm vs planktonic"
    }
  ],
  "acceptable_tool_classes": [
    "rna_seq_aligner",
    "feature_counter",
    "differential_expression"
  ],
  "acceptable_workflow_classes": [
    "STAR + featureCounts + DESeq2",
    "alternative RNA-seq DE workflow with equivalent gene-level outputs"
  ],
  "acceptable_solution_families": [
    "STAR + featureCounts + DESeq2",
    "equivalent_gene_level_DE_workflow"
  ],
  "iteration_policy": {
    "single_run_allowed": true,
    "multi_run_allowed": true,
    "max_attempts": 3,
    "material_change_rule": "A new attempt must modify preprocessing, tool selection, workflow structure, or one critical parameter.",
    "early_stop_rule": "Stop when a high-quality scientifically acceptable solution is reached."
  },
  "human_baseline_protocol": {
    "expertise_assumption": "computational biologist familiar with Galaxy RNA-seq workflows",
    "time_budget_minutes": 90,
    "tooling_access": "Galaxy plus public documentation"
  },
  "confidence_query_policy": {
    "mode": "post_plan",
    "scale": "0_to_1"
  },
  "scientific_acceptability_policy": {
    "review_mode": "hybrid_review",
    "acceptable_classes": [
      "acceptable but suboptimal differential expression workflow",
      "high-quality differential expression workflow"
    ],
    "rubric_reference": "docs/reviewer_readiness.md"
  },
  "evaluation_spec": {
    "primary_endpoint": "best_of_n_completion_rate",
    "scored_metrics": [
      "scientific_solution_score",
      "standard_analysis_score",
      "galaxy_execution_score",
      "first_run_completion_rate",
      "best_of_n_completion_rate",
      "improvement_trajectory",
      "tool_selection_accuracy",
      "workflow_coherence",
      "parameterization_accuracy",
      "preprocessing_accuracy",
      "result_quality",
      "scientific_acceptability",
      "confidence_calibration"
    ]
  },
  "ground_truth_contract": {
    "primary_output": "ranked_gene_table.csv",
    "required_fields": [
      "gene_id",
      "log2_fold_change",
      "p_value",
      "adjusted_p_value"
    ]
  },
  "tags": [
    "differential_expression",
    "galaxy",
    "biomedical"
  ]
}
